# -----------------------------
# ShipGen Backend Environment
# -----------------------------

# Core
SHIPGEN_ENV=local
SHIPGEN_APPROVAL_MODE=manual
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/shipgen

# Auth
SHIPGEN_JWT_SECRET=shipgen-dev-secret
SHIPGEN_JWT_TTL_SECONDS=28800
SHIPGEN_ADMIN_USERNAME=admin
SHIPGEN_ADMIN_PASSWORD=admin123

# Queue / Redis
SHIPGEN_QUEUE_BACKEND=redis
SHIPGEN_REDIS_URL=redis://localhost:6379/0
SHIPGEN_QUEUE_NAME=shipgen:jobs
SHIPGEN_DEAD_LETTER_QUEUE_NAME=shipgen:jobs:dlq

# Communication provider
# sandbox = works without real keys
# other value (example: twilio/custom) => keys required
SHIPGEN_COMM_PROVIDER=sandbox
SHIPGEN_WHATSAPP_API_KEY=
SHIPGEN_SMS_API_KEY=
SHIPGEN_PUSH_API_KEY=

# Routing/Maps provider
# sandbox = mock route generation
# other value (example: mapbox/google) => key required
SHIPGEN_ROUTE_PROVIDER=sandbox
SHIPGEN_MAPBOX_API_KEY=

# NLP provider
# sandbox = regex/mock extraction
# other value (example: openai) => key required
SHIPGEN_NLP_PROVIDER=sandbox
SHIPGEN_OPENAI_API_KEY=